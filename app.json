{
  "expo": {
    "name": "Naptune",
    "slug": "naptune",
    "scheme": "naptune",
    "version": "1.0.1",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#07091c"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.naptune.app",
      "buildNumber": "99",
      "supportsTablet": false,
      "infoPlist": {
        "CFBundleDisplayName": "Naptune",
        "CFBundleDevelopmentRegion": "ko"
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.naptune.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#07091c"
      }
    },
    "plugins": [
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "389dfafc-b202-46fe-a5b2-4d96704c8024"
      }
    },
    "owner": "iiwonkim"
  }
}
